{
  "name": "fishwale",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Ensure we can access our Supabase vars (assuming they are set in Cloudflare dashboard as well)
  "observability": {
    "enabled": true
  }
}
